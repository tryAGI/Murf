<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  <PropertyGroup Label="Nuget">
    <Description>C# SDK for the Murf AI API -- text-to-speech, 150+ voices, 35 languages, voice changer, and dubbing.</Description>
    <PackageId>Murf</PackageId>
    <PackageTags>api;client;sdk;dotnet;openapi;murf;text-to-speech;tts;ai;autosdk</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI" Version="10.4.1" />
  </ItemGroup>

</Project>
